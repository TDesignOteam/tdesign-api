{
  "name": "tdesign-api-statics",
  "version": "1.0.0",
  "scripts": {
    "dev": "vite",
    "watch": "vite build --watch",
    "build": "vite build",
    "lint:fix": "eslint --ext .vue,.js,.ts,.tsx ./packages --fix"
  },
  "dependencies": {
    "@codemirror/lang-javascript": "catalog:",
    "@codemirror/theme-one-dark": "catalog:",
    "@tdesign/site-components": "catalog:",
    "axios": "catalog:",
    "codemirror": "catalog:",
    "lodash": "catalog:",
    "tdesign-icons-vue-next": "catalog:",
    "tdesign-vue-next": "catalog:",
    "vue": "catalog:",
    "vue-codemirror": "catalog:",
    "vue-router": "catalog:"
  },
  "devDependencies": {
    "@commitlint/cli": "catalog:",
    "@commitlint/config-conventional": "catalog:",
    "@types/lodash": "catalog:",
    "@typescript-eslint/eslint-plugin": "catalog:",
    "@typescript-eslint/parser": "catalog:",
    "@vitejs/plugin-vue": "catalog:",
    "autoprefixer": "catalog:",
    "cssnano": "catalog:",
    "cz-conventional-changelog": "catalog:",
    "eslint": "catalog:",
    "eslint-config-standard": "catalog:",
    "eslint-plugin-import": "catalog:",
    "eslint-plugin-node": "catalog:",
    "eslint-plugin-promise": "catalog:",
    "eslint-plugin-vue": "catalog:",
    "less": "catalog:",
    "lint-staged": "catalog:",
    "postcss": "catalog:",
    "prismjs": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "lint-staged": {
    "*.{js,ts,vue,tsx}": [
      "npm run lint:fix",
      "git add"
    ]
  },
  "author": "tdesign",
  "license": "MIT"
