{
    "compilerOptions": {
        "module": "commonjs",
        "target": "es2017",
        "lib": ["es2017"],
        "rootDir": "./packages",
        "strict": true,
        "skipLibCheck": true,
        "outDir": "./dist",
        "sourceMap": false,
        "allowJs": false,
        "newLine": "LF",
        "esModuleInterop": true,
        "resolveJsonModule": true
    },
    "include": [
        "packages"
    ],
    "exclude": [
        "node_modules",
        "packages/products",
        "packages/scripts",
        "packages/model/dist"
    ]
}